# Copy to .env and fill in real values:  cp .env.example .env
# Never commit .env — it holds secrets.

# --- Admin login ------------------------------------------------------------
DOCNEST_ADMIN_USER=admin
DOCNEST_ADMIN_PASS=change-me-to-a-strong-password

# --- Session signing key (any long random string) ---------------------------
# Generate one:  python -c "import secrets; print(secrets.token_hex(32))"
DOCNEST_SECRET=change-me-to-a-random-64-char-hex-string

# --- Receipt / business settings --------------------------------------------
DOCNEST_DEFAULT_FEE=1000
DOCNEST_BUSINESS_NAME=DocNest Study Space
DOCNEST_CURRENCY=₹

# --- Cloudflare tunnel ------------------------------------------------------
# Zero Trust dashboard -> Networks -> Tunnels -> create tunnel -> copy the token
# from the "install connector" command (the long string after --token).
# Then add a Public Hostname: students.docnest.co.in -> http://app:8000
CLOUDFLARE_TUNNEL_TOKEN=paste-your-cloudflare-tunnel-token-here
